{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/pre-commit-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(docker compose *)",
      "Bash(python3 *)",
      "Bash(curl *)",
      "Bash(npm *)",
      "Bash(pip *)",
      "Write",
      "Edit"
    ]
  }
}