{
  "manifest_version": 3,
  "name": "Archive-35 CaFE Uploader",
  "version": "1.0.0",
  "description": "Upload photos to CallForEntry.org portfolio from Archive-35 CaFE Ready folders",
  "author": "Archive-35 Photography",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://artist.callforentry.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-128.png",
    "default_title": "CaFE Portfolio Uploader"
  },
  "content_scripts": [
    {
      "matches": ["https://artist.callforentry.org/*"],
      "js": ["lib/cafe-form-mapper.js", "content.js"],
      "all_frames": false
    }
  ]
}
